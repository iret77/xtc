#!/usr/bin/env bash
#
# Package the climbx-cowork Cowork plugin into climbx-cowork.plugin.
#
# The plugin no longer bundles the MCP server: .mcp.json launches it with
# `npx github:iret77/climbx-mcp`, so the archive is just the plugin components
# (skills, shared rules, the dashboard artifact, manifests). Run from anywhere.
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PLUGIN="$ROOT/plugin"
ARCHIVE="$ROOT/climbx-cowork.plugin"

command -v zip >/dev/null 2>&1 || { echo "build-plugin: 'zip' not found on PATH" >&2; exit 1; }

echo "==> Zipping plugin -> $ARCHIVE"
rm -f "$ARCHIVE"
( cd "$PLUGIN" && zip -r -q "$ARCHIVE" . -x '*.DS_Store' -x 'mcp-server/*' )

echo "==> Done: $ARCHIVE ($(du -h "$ARCHIVE" | cut -f1))"
